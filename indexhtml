        </div>

        <!-- ফটো গ্যালারি সেকশন -->
        <div class="card">
            <h2>আমার গ্যালারি (My Photos)</h2>
            <p>আমার কিছু প্রিয় মুহূর্ত ও ছবি নিচে দেওয়া হলো:</p>
            
            <div class="gallery-grid">
                <div class="gallery-item"><img src="34447.jpg" alt="Photo 1"></div>
                <div class="gallery-item"><img src="34446.jpg" alt="Photo 2"></div>
                <div class="gallery-item"><img src="34450.jpg" alt="Photo 3"></div>
                <div class="gallery-item"><img src="34449.jpg" alt="Photo 4"></div>
                <div class="gallery-item"><img src="34448.jpg" alt="Photo 5"></div>
                <div class="gallery-item"><img src="34445.jpg" alt="Photo 6"></div>
                <div class="gallery-item"><img src="34455.jpg" alt="Photo 7"></div>
            </div>
        </div>

        <!-- দক্ষতা সমূহ -->
        <div class="card">
            <h2>দক্ষতা ও পারদর্শিতা (Skills)</h2>
            <ul class="info-list">
                <li>স্মার্টফোন ও টেকনোলজি এক্সপার্ট</li>
                <li>মোবাইল ফটোগ্রাফি ও ইমেজ এডিটিং</li>
                <li>ডিজিটাল কনটেন্ট ক্রিয়েশন</li>
            </ul>
        </div>

        <!-- ঠিকানা ও যোগাযোগ -->
        <div class="card">
            <h2>যোগাযোগ ও ঠিকানা (Contact & Address)</h2>
            <p>যেকোনো প্রয়োজনে বা বিস্তারিত জানতে নিচের মাধ্যমে যোগাযোগ করতে পারেন:</p>
            <p>
                <strong>📍 ঠিকানা:</strong> সরদারহাট,ডিমলা, রংপুর, বাংলাদেশ <br><br>
                <strong>📧 ইমেইল:</strong> contact@graphic399@gmail.com
            </p>
            <a href="mailto:contact@graphic399@gmail.com" class="btn-contact">আমাকে ইমেইল করুন</a>
        </div>

    </div>

    <!-- ফুটার -->
    <footer>
        <p>&copy; 2026 | www.graphic399@gmail.com | সর্বস্বত্ব সংরক্ষিত</p>
    </footer>

</body>
</html>